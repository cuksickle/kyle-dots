{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "opencode-mcp-tool-search@latest",
    "opencode-firecrawl@latest",
    "opencode-pty@latest",
    "opencode-md-table-formatter@latest"
  ],
  "mcp": {
    "nanobanana": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/home/kyle/nanobanana-mcp-server",
        "run",
        "python",
        "-m",
        "nanobanana_mcp_server.server"
      ],
      "enabled": true,
      "environment": {
        "GEMINI_API_KEY": "{env:NANOBANANA_GEMINI_API_KEY}",
        "FASTMCP_SHOW_CLI_BANNER": "false",
        "LOG_LEVEL": "WARNING"
      }
    },
    "notion-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "enabled": true
    },
    "github-mcp-server": {
      "enabled": false,
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "env:GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    "kyle-utility-mcp": {
      "type": "local",
      "command": [
        "python3",
        "/home/kyle/git/kyle-utility-mcp/server.py"
      ],
      "enabled": false
    },
    "thinking-monolith": {
      "type": "local",
      "command": [
        "npx",
        "ts-node",
        "--esm",
        "/home/kyle/git/thinking-monolith-mcp/index.ts"
      ],
      "enabled": true
    },
    "pedagogy-mcp": {
      "type": "local",
      "command": [
        "npx",
        "tsx",
        "/home/kyle/git/teaching/pedagogy-mcp/src/index.ts"
      ],
      "enabled": true,
      "environment": {
        "BASE_DIR": "/home/kyle/git/teaching/pedagogy-mcp"
      }
    },
    "atlas-mcp": {
      "type": "local",
      "command": [
        "/home/kyle/git/kyle-utility-mcp/venv/bin/python",
        "/home/kyle/git/kyle-utility-mcp/server.py"
      ],
      "enabled": true,
      "environment": {
        "PATH": "/home/kyle/bin/go/bin:/usr/local/bin:/usr/bin:/bin",
        "PYTHONPATH": "/home/kyle/git/external-knowledge/OpenViking"
      }
    },
    "brainstorm-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "brainstorm-mcp"
      ],
      "enabled": true,
      "environment": {
        "OPENAI_API_KEY": "{env:OPENAI_API_KEY}"
      }
    },
    "web-monolith": {
      "type": "local",
      "command": [
        "node",
        "/home/kyle/git/web-monolith-mcp/dist/index.js"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "specmatic-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "specmatic-mcp"
      ],
      "enabled": true
    },
    "obsidian-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bitbonsai/mcpvault@latest",
        "/home/kyle/Nextcloud/Documents/Obsidian Vault"
      ],
      "enabled": true
    },
    "notebooklm-mcp": {
      "type": "local",
      "command": [
        "node",
        "/home/kyle/git/external-knowledge/notebooklm-mcp/dist/index.js"
      ],
      "enabled": true,
      "environment": {
        "BROWSER_CHANNEL": "chrome"
      }
    },
    "openspace": {
      "type": "local",
      "command": [
        "openspace-mcp"
      ],
      "enabled": true,
      "environment": {
        "OPENSPACE_HOST_SKILL_DIRS": "/home/kyle/.config/opencode/skills",
        "OPENSPACE_WORKSPACE": "/home/kyle/git/tools/OpenSpace"
      }
    }
  },
  "permission": {
    "webfetch": "deny"
  },
  "provider": {
    "google": {
      "name": "Google",
      "models": {
        "antigravity-gemini-3.1-pro": {
