{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "nanobanana": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/home/kyle/nanobanana-mcp-server",
        "run",
        "python",
        "-m",
        "nanobanana_mcp_server.server"
      ],
      "enabled": true,
      "environment": {
        "GEMINI_API_KEY": "AIzaSyDxyW4_WNsn2xxSCYAetoMEdCzCUaY6qJ4",
        "FASTMCP_SHOW_CLI_BANNER": "false",
        "LOG_LEVEL": "WARNING"
      }
    },
    "notion-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "enabled": true
    },
    "function-gemma": {
      "type": "local",
      "command": [
        "python3",
        "/home/kyle/git/research/local-llm/mcp_server_gemma.py"
      ],
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "BSAmCMzKSQDF4Iijz6cQvwTc_TRmn58"
      }
    },
    "github-mcp-server": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "env:GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    "pagemap": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "/home/kyle/git/Retio-pagemap",
        "run",
        "retio-pagemap",
        "--allow-local"
      ],
      "enabled": true
    },
    "kyle-utility-mcp": {
      "type": "local",
      "command": [
        "python3",
        "/home/kyle/git/kyle-utility-mcp/server.py"
      ],
      "enabled": false
    },
    "thinking-monolith": {
      "type": "local",
      "command": [
        "npx",
        "ts-node",
        "--esm",
        "/home/kyle/git/thinking-monolith-mcp/index.ts"
      ],
      "enabled": true
    },
    "pedagogy-monolith": {
      "type": "local",
      "command": [
        "npx",
        "tsx",
        "/home/kyle/git/pedagogy-mcp/index.ts"
      ],
      "enabled": true,
      "environment": {
        "BASE_DIR": "/home/kyle/git/pedagogy-mcp"
      }
    }
  },
  "provider": {
    "google": {
      "name": "Google",
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
